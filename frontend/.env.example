# Browser-side API base.
# Keep empty to use Next.js rewrites through /api and /ws.
NEXT_PUBLIC_API_URL=

# Server-side API base for Next.js rewrites.
# Local dev:
NEXT_SERVER_API_URL=http://localhost:8000

# Docker compose:
# NEXT_SERVER_API_URL=http://backend:8000

# Optional static bearer token for non-interactive deployments.
NEXT_PUBLIC_AUTH_TOKEN=

# Optional direct websocket URL for alerts.
# Set this on Vercel when backend websocket is hosted on a separate domain.
# Example: wss://api.your-domain.com/ws/alerts
NEXT_PUBLIC_WS_URL=

# Fallback polling when websocket is unavailable (recommended true for serverless hosts).
NEXT_PUBLIC_ENABLE_ALERT_POLLING=true
