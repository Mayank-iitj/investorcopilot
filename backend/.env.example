APP_NAME=AI Investor Copilot
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_JSON=false
ENABLE_DOCS=true
AUTO_INIT_DB=true

# Local default (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./copilot.db

# Production example (Postgres)
# DATABASE_URL=postgresql+asyncpg://investor:investor_secret@postgres:5432/investor_copilot

# Security / network
CORS_ORIGINS=http://localhost:3000
TRUSTED_HOSTS=localhost,127.0.0.1

# Auth (set AUTH_ENABLED=true in production)
AUTH_ENABLED=false
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
ADMIN_USERNAME=admin
# Generate with Python:
# from passlib.context import CryptContext; print(CryptContext(schemes=["bcrypt"]).hash("your-password"))
ADMIN_PASSWORD_HASH=

# Request and upstream guardrails
EXTERNAL_API_TIMEOUT_SECONDS=15
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_SENSITIVE=20/minute

# Observability
ENABLE_METRICS=true
ENABLE_SENTRY=false
SENTRY_DSN=

# Optional services
REDIS_URL=redis://localhost:6379/0
GROQ_API_KEY=
NEWS_API_KEY=
ALPHA_VANTAGE_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Signal tuning
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30
MA_SHORT=50
MA_LONG=200
BREAKOUT_WINDOW=20
VOLUME_SPIKE_THRESHOLD=2.0
DEFAULT_BACKTEST_YEARS=2

# Realtime scanning loop
REALTIME_SCAN_ENABLED=true
REALTIME_SCAN_INTERVAL_SECONDS=120
REALTIME_SCAN_DAYS_BACK=5
